# ===========================
#  Experiment 9 — .gitignore
# ===========================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# Node modules
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
frontend/dist/
frontend/build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.user

# Docker volumes (local data)
mongo-data/
